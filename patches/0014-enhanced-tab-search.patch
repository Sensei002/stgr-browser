+/* =========================================================================
+   STGR Browser: Enhanced Tab Search
+   =========================================================================
+   Search icon, fuzzy highlighting, keyboard navigation, result count badge.
+   ========================================================================= */
+
+/* --- SEARCH CONTAINER ------------------------------------------------- */
+.stgr-vertical-tabs-search-container {
+  align-items: center;
+  display: flex;
+  flex-direction: row;
+  gap: 4px;
+  position: relative;
+}
+
+/* --- SEARCH ICON ------------------------------------------------------ */
+.stgr-vertical-tabs-search-icon {
+  flex-shrink: 0;
+  height: 12px;
+  margin-inline-end: -20px;
+  opacity: 0.4;
+  pointer-events: none;
+  position: relative;
+  width: 12px;
+  z-index: 1;
+}
+
+/* --- SEARCH INPUT ----------------------------------------------------- */
+.stgr-vertical-tabs-search {
+  -moz-appearance: none;
+  appearance: none;
+  background-color: var(--stgr-bg-surface-alt, #1E1E1E);
+  border: 1px solid var(--stgr-border, #2A2A2A);
+  border-radius: 6px;
+  color: var(--stgr-text-primary, #E8E8E8);
+  flex: 1;
+  font-size: 12px;
+  outline: none;
+  padding: 6px 10px 6px 24px;
+  transition: border-color 0.15s ease, background-color 0.15s ease;
+  width: 100%;
+  box-sizing: border-box;
+}
+
+.stgr-vertical-tabs-search:focus {
+  border-color: var(--stgr-accent-primary, #C41E3A);
+  background-color: var(--stgr-bg-surface, #141414);
+}
+
+.stgr-vertical-tabs-search::placeholder {
+  color: var(--stgr-text-secondary, #909090);
+  opacity: 1;
+}
+
+/* Filter-active state on the header */
+.stgr-vertical-tabs-header[filter-active="true"] {
+  border-block-end-color: var(--stgr-accent-primary, #C41E3A);
+}
+
+/* --- CLEAR BUTTON ----------------------------------------------------- */
+.stgr-vertical-tabs-search-clear {
+  -moz-appearance: none;
+  appearance: none;
+  background: transparent;
+  border: none;
+  border-radius: 3px;
+  cursor: default;
+  flex-shrink: 0;
+  height: 14px;
+  list-style-image: url("chrome://global/skin/icons/close.svg");
+  margin-inline-start: -24px;
+  opacity: 0;
+  padding: 0;
+  position: relative;
+  transition: opacity 0.12s ease;
+  width: 14px;
+  z-index: 1;
+}
+
+.stgr-vertical-tabs-search-clear:not([hidden]) {
+  opacity: 0.4;
+}
+
+.stgr-vertical-tabs-search-clear:hover {
+  opacity: 0.8 !important;
+}
+
+/* --- SEARCH COUNT BADGE ----------------------------------------------- */
+.stgr-vertical-tabs-search-count {
+  color: var(--stgr-text-secondary, #909090);
+  flex-shrink: 0;
+  font-size: 10px;
+  margin-inline-start: auto;
+  padding: 2px 6px;
+  user-select: none;
+  white-space: nowrap;
+}
+
+/* --- SEARCH HIGHLIGHT ------------------------------------------------- */
+/* Matched characters in tab labels during search */
+.stgr-vertical-tab-search-highlight {
+  text-decoration: underline;
+  text-decoration-color: var(--stgr-accent-primary, #C41E3A);
+  text-underline-offset: 2px;
+  text-decoration-thickness: 1.5px;
+}
+
+/* --- KEYBOARD NAVIGATION FOCUS --------------------------------------- */
+.stgr-vertical-tab[search-focused="true"] {
+  background-color: var(--stgr-bg-surface-alt, #1E1E1E);
+  outline: 1px solid var(--stgr-accent-primary, #C41E3A);
+  outline-offset: -1px;
+}
+
+.stgr-vertical-tab[search-focused="true"][selected="true"] {
+  outline: 2px solid var(--stgr-accent-primary, #C41E3A);
+  outline-offset: -2px;
+}
+
+/* --- FOCUSED CONTAINER STATE ------------------------------------------ */
+.stgr-vertical-tabs-search-container[focused="true"] .stgr-vertical-tabs-search {
+  border-color: var(--stgr-accent-primary, #C41E3A);
+}
+
+.stgr-vertical-tabs-search-container[focused="true"] .stgr-vertical-tabs-search-icon {
+  opacity: 0.7;
+}
+
+/* --- ANIMATED FILTER ENTRY ------------------------------------------- */
+.stgr-vertical-tab[filter-hidden="true"] {
+  display: none;
+}
+
+.stgr-vertical-tabs-header[filter-active="true"] .stgr-vertical-tab:not([filter-hidden]) {
+  animation: stgrSearchReveal 0.15s ease-out both;
+}
+
+@keyframes stgrSearchReveal {
+  from {
+    opacity: 0;
+    transform: translateX(-8px);
+  }
+  to {
+    opacity: 1;
+    transform: translateX(0);
+  }
+}
