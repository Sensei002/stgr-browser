+  _getHighlightSegments(query, label) {
+    if (!query || !this._searchFuzzy) {
+      return [{ text: label, highlighted: false }];
+    }
+
+    const q = query.toLowerCase();
+    const l = label.toLowerCase();
+    const segments = [];
+    let qi = 0;
+    let lastEnd = 0;
+
+    for (let li = 0; li < l.length && qi < q.length; li++) {
+      if (l[li] === q[qi]) {
+        // Non-highlighted text before this match
+        if (li > lastEnd) {
+          segments.push({
+            text: label.slice(lastEnd, li),
+            highlighted: false,
+          });
+        }
+        // Highlighted match character
+        segments.push({
+          text: label[li],
+          highlighted: true,
+        });
+        lastEnd = li + 1;
+        qi++;
+      }
+    }
+
+    // Remaining text after last match
+    if (lastEnd < label.length) {
+      segments.push({
+        text: label.slice(lastEnd),
+        highlighted: false,
+      });
+    }
+
+    return segments;
+  }
