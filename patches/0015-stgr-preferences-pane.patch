+stgr-vertical-tabs-width =
+  .label = Sidebar width
+stgr-vertical-tabs-auto-hide =
+  .label = Auto-hide sidebar
+stgr-vertical-tabs-show-preview =
+  .label = Show tab preview on hover
+stgr-vertical-tabs-search-enabled =
+  .label = Enable tab search
+stgr-vertical-tabs-search-fuzzy =
+  .label = Fuzzy search
+stgr-vertical-tabs-search-urls =
+  .label = Search page URLs
+stgr-vertical-tabs-animations =
+  .label = Enable animations
+
+## Tab Groups
+stgr-tab-groups-header =
+  .label = Tab Groups
+stgr-tab-groups-enabled =
+  .label = Enable tab groups
+stgr-tab-groups-show-color-dot =
+  .label = Show color indicator
+stgr-tab-groups-collapse-on-startup =
+  .label = Collapse on startup
+
+## Tab Preview
+stgr-tab-preview-header =
+  .label = Tab Preview Thumbnail
+stgr-tab-preview-width =
+  .label = Thumbnail width
+stgr-tab-preview-height =
+  .label = Thumbnail height
+stgr-tab-preview-quality =
+  .label = JPEG quality
+
+## Gaming Mode
+stgr-gaming-mode-header =
+  .label = Gaming Mode
+stgr-gaming-mode-enabled =
+  .label = Enable Gaming Mode
+
+## About
+stgr-about-header =
+  .label = About STGR Browser
+stgr-about-version =
+  .label = Version
+stgr-about-build =
+  .label = Build ID
+stgr-about-platform =
+  .label = Platform
