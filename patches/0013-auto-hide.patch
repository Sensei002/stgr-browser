+  /**
+   * Initialize auto-hide behavior.
+   * Checks the stgr.verticalTabs.autoHide pref and sets up event
+   * listeners and visual state.
+   */
+  _setupAutoHide() {
+    this._autoHideEnabled = Services.prefs.getBoolPref(
+      "stgr.verticalTabs.autoHide", false);
+
+    if (!this._autoHideEnabled) return;
+
+    this._panel.setAttribute("autohide", "true");
+    this._applyAutoHidePositioning(true);
+    this._collapseAutoHide(true);
+
+    // Hover events: expand on enter with short delay,
+    // collapse on leave with longer delay (cancellable)
+    this._panel.addEventListener("mouseenter", () => {
+      if (!this._autoHideEnabled) return;
+      this._clearAutoHideTimeout();
+      this._autoHideTimeout = this._win.setTimeout(() => {
+        this._expandAutoHide();
+      }, 100);
+    });
+
+    this._panel.addEventListener("mouseleave", (e) => {
+      if (!this._autoHideEnabled) return;
+      this._clearAutoHideTimeout();
+      // Don't collapse if pinned or if mouse entered a child popup
+      if (this._autoHidePinned) return;
+      // Check if mouse actually left the panel (not entering a child popup)
+      const related = e.relatedTarget;
+      if (related && this._panel.contains(related)) return;
+      this._autoHideTimeout = this._win.setTimeout(() => {
+        this._collapseAutoHide();
+      }, 800);
+    });
+
+    // Click outside to collapse (when expanded and unpinned)
+    this._autoDocClickListener = (e) => {
+      if (!this._autoHideEnabled || this._autoHidePinned) return;
+      if (!this._panel.hasAttribute("expanded")) return;
+      // Don't collapse if clicking inside the panel or on the panel itself
+      if (this._panel.contains(e.target) || e.target === this._panel) return;
+      this._collapseAutoHide();
+    };
+    // Use capture phase to intercept clicks before they reach content
+    this._win.document.addEventListener("click", this._autoDocClickListener, true);
+
+    // Watch for pref changes to enable/disable auto-hide live
+    this._autoPrefObserver = (subject, topic, data) => {
+      if (data === "stgr.verticalTabs.autoHide") {
+        this._autoHideEnabled = Services.prefs.getBoolPref(
+          "stgr.verticalTabs.autoHide", false);
+        this._onAutoHidePrefChanged();
+      }
+    };
+    Services.prefs.addObserver("stgr.verticalTabs.autoHide",
+      this._autoPrefObserver);
+  }
