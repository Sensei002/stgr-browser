@@ -0,0 +1,280 @@
+/* -*- Mode: JS; tab-width: 2; indent-tabs-mode: nil; c-basic-offset: 2 -*- */
+/* This Source Code Form is subject to the terms of the Mozilla Public
+ * License, v. 2.0. If a copy of the MPL was not distributed with this
+ * file, You can obtain one at http://mozilla.org/MPL/2.0/. */
+
+"use strict";
+
+const EXPORTED_SYMBOLS = ["TabGroupsManager"];
+
+const GROUP_COLORS = [
+  { name: "Red",      hex: "#C41E3A" },
+  { name: "Green",    hex: "#00E676" },
+  { name: "Orange",   hex: "#FF9100" },
+  { name: "Purple",   hex: "#B388FF" },
+  { name: "Pink",     hex: "#FF80AB" },
+  { name: "Red",      hex: "#FF5252" },
+  { name: "Yellow",   hex: "#FFD600" },
+  { name: "Teal",     hex: "#1DE9B6" },
+];
+
+const STORAGE_PREF = "stgr.tabGroups.data";
+
+// ===========================================================================
+// TabGroupsManager - Singleton managing tab group definitions and membership
+// ===========================================================================
+//
+// Data Model:
+//   groups: Map<groupId, { id, name, color, collapsed, order, tabIds: Set }>
+//   _tabGroup: WeakMap<tab, groupId>
+//
+// Persistence:
+//   - Group definitions are stored as JSON in stgr.tabGroups.data pref
+//   - Tab-group membership is stored via the "stgrGroupId" attribute on the
+//     <tab> XUL element, which Firefox's session store serializes.
+//   - The WeakMap provides fast runtime lookup and is repopulated from the
+//     attribute on tab creation / session restore.
+//
+// ===========================================================================
+
+let _instance = null;
+
+class TabGroupsManager {
+  constructor() {
+    if (_instance) return _instance;
+    this._groups = new Map();
+    this._tabGroup = new WeakMap();
+    this._nextId = 1;
+    this._loaded = false;
+    this._listeners = new Map();
+    _instance = this;
+  }
+
+  static getInstance() {
+    if (!_instance) new TabGroupsManager();
+    return _instance;
+  }
+
+  // -----------------------------------------------------------------------
+  // PERSISTENCE
+  // -----------------------------------------------------------------------
+
+  load() {
+    if (this._loaded) return;
+    this._loaded = true;
+    try {
+      const json = Services.prefs.getCharPref(STORAGE_PREF, "");
+      if (!json) return;
+      const data = JSON.parse(json);
+      for (const entry of data.groups || []) {
+        this._groups.set(entry.id, {
+          id: entry.id,
+          name: entry.name || "Group",
+          color: entry.color || GROUP_COLORS[0].hex,
+          collapsed: !!entry.collapsed,
+          order: entry.order || 0,
+          tabIds: new Set(entry.tabIds || []),
+        });
+      }
+      this._nextId = data.nextId || this._groups.size + 1;
+    } catch (e) {
+      console.error("STGR TabGroups: Failed to load groups", e);
+    }
+  }
+
+  save() {
+    const data = {
+      nextId: this._nextId,
+      groups: Array.from(this._groups.values()).map(g => ({
+        id: g.id,
+        name: g.name,
+        color: g.color,
+        collapsed: g.collapsed,
+        order: g.order,
+        tabIds: Array.from(g.tabIds),
+      })),
+    };
+    Services.prefs.setCharPref(STORAGE_PREF, JSON.stringify(data));
+  }
+
+  // -----------------------------------------------------------------------
+  // GROUP CRUD
+  // -----------------------------------------------------------------------
+
+  createGroup(name, color) {
+    const id = String(this._nextId++);
+    const group = {
+      id,
+      name: name || `Group ${this._groups.size + 1}`,
+      color: color || GROUP_COLORS[this._groups.size % GROUP_COLORS.length].hex,
+      collapsed: false,
+      order: this._groups.size,
+      tabIds: new Set(),
+    };
+    this._groups.set(id, group);
+    this._emit("group-added", { groupId: id });
+    this.save();
+    return id;
+  }
+
+  deleteGroup(groupId) {
+    const group = this._groups.get(groupId);
+    if (!group) return;
+    for (const tabId of group.tabIds) {
+      const tab = this._findTabById(tabId);
+      if (tab) tab.removeAttribute("stgrGroupId");
+    }
+    this._groups.delete(groupId);
+    this._emit("group-removed", { groupId });
+    this.save();
+  }
+
+  renameGroup(groupId, name) {
+    const group = this._groups.get(groupId);
+    if (!group) return;
+    group.name = name;
+    this._emit("group-changed", { groupId });
+    this.save();
+  }
+
+  setGroupColor(groupId, color) {
+    const group = this._groups.get(groupId);
+    if (!group) return;
+    group.color = color;
+    this._emit("group-changed", { groupId });
+    this.save();
+  }
+
+  toggleCollapsed(groupId) {
+    const group = this._groups.get(groupId);
+    if (!group) return;
+    group.collapsed = !group.collapsed;
+    this._emit("group-changed", { groupId });
+    this.save();
+  }
+
+  collapseAll() {
+    for (const group of this._groups.values()) {
+      group.collapsed = true;
+    }
+    this._emit("groups-collapsed-all");
+    this.save();
+  }
+
+  // -----------------------------------------------------------------------
+  // TAB MEMBERSHIP
+  // -----------------------------------------------------------------------
+
+  /** Get a stable identifier for a tab for persistence. */
+  _tabId(tab) {
+    // outerWindowID is stable across session restore.
+    // linkedPanel is available for active tabs.
+    return tab.linkedBrowser?.outerWindowID ||
+           tab.linkedPanel ||
+           tab.getAttribute("id");
+  }
+
+  addTabToGroup(tab, groupId) {
+    const group = this._groups.get(groupId);
+    if (!group) return;
+    this.removeTabFromGroup(tab);
+    tab.setAttribute("stgrGroupId", groupId);
+    group.tabIds.add(this._tabId(tab));
+    this._tabGroup.set(tab, groupId);
+    this._emit("tab-added-to-group", { tab, groupId });
+    this.save();
+  }
+
+  removeTabFromGroup(tab) {
+    const groupId = this._tabGroup.get(tab) || tab.getAttribute("stgrGroupId");
+    if (!groupId) return;
+    const group = this._groups.get(groupId);
+    if (group) {
+      group.tabIds.delete(this._tabId(tab));
+    }
+    tab.removeAttribute("stgrGroupId");
+    this._tabGroup.delete(tab);
+    this._emit("tab-removed-from-group", { tab, groupId });
+    this.save();
+  }
+
+  getGroupForTab(tab) {
+    let id = this._tabGroup.get(tab);
+    if (!id) {
+      id = tab.getAttribute("stgrGroupId");
+      if (id && this._groups.has(id)) {
+        this._tabGroup.set(tab, id);
+      }
+    }
+    return id || null;
+  }
+
+  getGroupDataForTab(tab) {
+    const id = this.getGroupForTab(tab);
+    return id ? this._groups.get(id) || null : null;
+  }
+
+  getTabsInGroup(win, groupId) {
+    return Array.from(win.gBrowser.tabs).filter(
+      t => this.getGroupForTab(t) === groupId
+    );
+  }
+
+  restoreTabGroup(tab) {
+    const groupId = tab.getAttribute("stgrGroupId");
+    if (groupId && this._groups.has(groupId)) {
+      this._tabGroup.set(tab, groupId);
+    }
+  }
+
+  // -----------------------------------------------------------------------
+  // QUERIES
+  // -----------------------------------------------------------------------
+
+  getGroups() {
+    return Array.from(this._groups.values()).sort((a, b) => a.order - b.order);
+  }
+
+  getGroup(groupId) { return this._groups.get(groupId) || null; }
+  getGroupIds() { return Array.from(this._groups.keys()); }
+  getPresetColors() { return GROUP_COLORS; }
+
+  // -----------------------------------------------------------------------
+  // EVENTS
+  // -----------------------------------------------------------------------
+
+  on(event, callback) {
+    if (!this._listeners.has(event)) this._listeners.set(event, new Set());
+    this._listeners.get(event).add(callback);
+  }
+
+  off(event, callback) {
+    this._listeners.get(event)?.delete(callback);
+  }
+
+  _emit(event, data) {
+    for (const cb of this._listeners.get(event) || []) {
+      try { cb(data); } catch (e) { console.error("STGR TabGroups error", e); }
+    }
+  }
+
+  // -----------------------------------------------------------------------
+  // UTILITY
+  // -----------------------------------------------------------------------
+
+  _findTabById(tabId) {
+    if (!tabId) return null;
+    const windows = Services.wm.getEnumerator("navigator:browser");
+    while (windows.hasMoreElements()) {
+      const win = windows.getNext();
+      for (const tab of win.gBrowser.tabs) {
+        if (this._tabId(tab) === tabId) return tab;
+      }
+    }
+    return null;
+  }
+}

