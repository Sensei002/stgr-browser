# STGR Browser - Platform-Detecting mozconfig
# ============================================================================
# This file auto-detects the build platform and includes the correct
# platform-specific configuration. Do not edit this file directly —
# instead, modify the corresponding platform file:
#
#   config/mozconfig-windows  (Windows x64)
#   config/mozconfig-linux    (Linux x86_64)
#   config/mozconfig-macos    (macOS x86_64 / ARM64)
#
# To force a specific platform (e.g., cross-compiling), set the
# STGR_MOZCONFIG_PLATFORM environment variable to one of:
#   "windows", "linux", "macos"
# ============================================================================

# Auto-detect platform
# Note: Mozilla's mach reads mozconfig from the source directory, so this
# file must be copied to the source tree by setup.sh. It uses shell
# detection to include the right platform config.

# Helper: safely source a config file if it exists
_load_config() {
    [ -f "$1" ] && . "$1" || true
}

# Platform detection (run by mach before build)
_UNAME_S=$(uname -s 2>/dev/null || echo "unknown")

case "$_UNAME_S" in
    Linux*)
        # Linux build — use GTK3 toolkit
        _load_config "$topsrcdir/config/mozconfig-linux"
        ;;
    Darwin*)
        # macOS build — use Cocoa toolkit
        _load_config "$topsrcdir/config/mozconfig-macos"
        ;;
    CYGWIN*|MINGW*|MSYS*|MINGW32*|MINGW64*)
        # Windows build — use cairo-windows toolkit
        _load_config "$topsrcdir/config/mozconfig-windows"
        ;;
    *)
        echo "STGR: Unknown platform '$_UNAME_S'. Defaulting to Linux config."
        _load_config "$topsrcdir/config/mozconfig-linux"
        ;;
esac

# Allow override via environment variable
if [ -n "${STGR_MOZCONFIG_PLATFORM:-}" ]; then
    case "$STGR_MOZCONFIG_PLATFORM" in
        windows) _load_config "$topsrcdir/config/mozconfig-windows" ;;
        linux)   _load_config "$topsrcdir/config/mozconfig-linux" ;;
        macos)   _load_config "$topsrcdir/config/mozconfig-macos" ;;
    esac
fi
