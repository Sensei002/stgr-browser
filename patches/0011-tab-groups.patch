diff --git a/browser/components/verticaltabs/content/vertical-tabs.css b/browser/components/verticaltabs/content/vertical-tabs.css
index 000000000000..000000000000
--- a/browser/components/verticaltabs/content/vertical-tabs.css
+++ b/browser/components/verticaltabs/content/vertical-tabs.css
@@ -302,3 +302,104 @@
 .stgr-vertical-tabs-context menuseparator {
   border-block-start: 1px solid var(--stgr-border, #2A2A3E);
   margin: 4px 8px;
 }
+
+/* =========================================================================
+   STGR Browser: Tab Groups
+   ========================================================================= */
+
+.stgr-vertical-tabs-groups {
+  display: flex;
+  flex-direction: column;
+}
+
+/* --- GROUP HEADER --------------------------------------------------- */
+.stgr-vertical-tabs-group-header {
+  -moz-appearance: none;
+  align-items: center;
+  background-color: transparent;
+  border-radius: 6px;
+  cursor: pointer;
+  display: flex;
+  flex-direction: row;
+  gap: 4px;
+  margin: 2px 6px 1px;
+  min-height: 28px;
+  padding: 2px 8px 2px 12px;
+  position: relative;
+  user-select: none;
+  transition: background-color 0.12s ease;
+}
+
+.stgr-vertical-tabs-group-header:hover {
+  background-color: var(--stgr-hover, #1A1A2E);
+}
+
+.stgr-vertical-tabs-group-header[drag-hover="true"] {
+  background-color: var(--stgr-bg-surface-alt, #1A1A2E);
+  box-shadow: inset 0 0 0 2px var(--stgr-accent-primary, #C41E3A);
+}
+
+.stgr-vertical-tabs-group-chevron {
+  flex-shrink: 0;
+  height: 10px;
+  list-style-image: url("chrome://global/skin/icons/arrow-down-12.svg");
+  opacity: 0.5;
+  transition: transform 0.15s ease, opacity 0.12s ease;
+  width: 10px;
+}
+
+.stgr-vertical-tabs-group-chevron[collapsed] {
+  transform: rotate(-90deg);
+}
+
+.stgr-vertical-tabs-group-header:hover .stgr-vertical-tabs-group-chevron {
+  opacity: 0.8;
+}
+
+.stgr-vertical-tabs-group-dot {
+  border-radius: 50%;
+  flex-shrink: 0;
+  height: 8px;
+  width: 8px;
+}
+
+.stgr-vertical-tabs-group-name {
+  color: var(--stgr-text-primary, #E8E8F0);
+  cursor: pointer;
+  flex: 1;
+  font-size: 11px;
+  font-weight: 600;
+  overflow: hidden;
+  text-overflow: ellipsis;
+  white-space: nowrap;
+}
+
+.stgr-vertical-tabs-group-count {
+  background-color: var(--stgr-bg-surface-alt, #1A1A2E);
+  border-radius: 8px;
+  color: var(--stgr-text-secondary, #9090A0);
+  flex-shrink: 0;
+  font-size: 9px;
+  font-weight: 600;
+  line-height: 14px;
+  min-width: 14px;
+  padding: 0 4px;
+  text-align: center;
+}
+
+.stgr-vertical-tabs-group-close {
+  -moz-appearance: none;
+  appearance: none;
+  background: none;
+  border: none;
+  flex-shrink: 0;
+  height: 14px;
+  list-style-image: url("chrome://global/skin/icons/close.svg");
+  opacity: 0;
+  padding: 0;
+  transition: opacity 0.12s ease;
+  width: 14px;
+}
+
+.stgr-vertical-tabs-group-header:hover .stgr-vertical-tabs-group-close {
+  opacity: 0.5;
+}
+
+.stgr-vertical-tabs-group-close:hover {
+  opacity: 1 !important;
+}
+
+.stgr-vertical-tabs-group-list {
+  display: flex;
+  flex-direction: column;
+  overflow: hidden;
+  transition: max-height 0.2s ease, opacity 0.15s ease;
+}
+
+.stgr-vertical-tabs-group-list[collapsed] {
+  display: none;
+}
+
+/* Grouped tab indentation */
+.stgr-vertical-tab[group] {
+  margin-inline-start: 18px !important;
+  padding-inline-start: 6px !important;
+}
+
+/* Group context menu */
+.stgr-vertical-tabs-context {
+  -moz-appearance: none;
+  background-color: var(--stgr-bg-surface, #14141F);
+  border: 1px solid var(--stgr-border, #2A2A3E);
+  border-radius: 8px;
+  padding: 4px;
+  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
+}
+
+.stgr-vertical-tabs-context menuitem,
+.stgr-vertical-tabs-context menu {
+  -moz-appearance: none;
+  background: transparent;
+  border: none;
+  border-radius: 4px;
+  color: var(--stgr-text-primary, #E8E8F0);
+  font-size: 11px;
+  padding: 6px 24px 6px 12px;
+  transition: background-color 0.12s ease;
+}
+
+.stgr-vertical-tabs-context menuitem:hover,
+.stgr-vertical-tabs-context menu:hover {
+  background-color: var(--stgr-hover, #1A1A2E);
+}
+
+.stgr-vertical-tabs-context menuseparator {
+  border-block-start: 1px solid var(--stgr-border, #2A2A3E);
+  margin: 4px 8px;
+}

