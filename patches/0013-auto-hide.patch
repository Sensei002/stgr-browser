--- a/browser/components/verticaltabs/content/vertical-tabs.css
+++ b/browser/components/verticaltabs/content/vertical-tabs.css
@@ -407,3 +407,84 @@
 .stgr-vertical-tabs-context menuseparator {
   border-block-start: 1px solid var(--stgr-border, #2A2A3E);
   margin: 4px 8px;
 }
+
+/* =========================================================================
+   STGR Browser: Auto-Hide Vertical Tabs
+   =========================================================================
+   When enabled, the sidebar collapses to a thin 12px strip on the left edge
+   and expands on hover (VSCode-style). Uses absolute positioning to overlay
+   browser content. Smooth transitions for width, opacity, and shadow.
+   ========================================================================= */
+
+/* --- COLLAPSED STATE ------------------------------------------------ */
+.stgr-vertical-tabs-panel[autohide="true"] {
+  position: absolute !important;
+  left: 0 !important;
+  top: 0 !important;
+  bottom: 0 !important;
+  z-index: 100 !important;
+  width: 12px !important;
+  min-width: 12px !important;
+  max-width: 12px !important;
+  overflow: hidden;
+  opacity: 0.6;
+  border-inline-end: 1px solid var(--stgr-border, #2A2A3E);
+  background-color: var(--stgr-bg-surface, #14141F);
+  cursor: pointer;
+  transition: width 0.2s ease-in-out,
+              opacity 0.2s ease,
+              min-width 0.2s ease-in-out,
+              max-width 0.2s ease-in-out,
+              box-shadow 0.2s ease-in-out;
+}
+
+.stgr-vertical-tabs-panel[autohide="true"]:hover {
+  opacity: 0.85;
+}
+
+/* --- EXPANDED STATE ------------------------------------------------- */
+.stgr-vertical-tabs-panel[autohide="true"][expanded="true"] {
+  width: var(--stgr-vt-expanded-width, 260px) !important;
+  min-width: 200px !important;
+  max-width: 400px !important;
+  opacity: 1;
+  cursor: default;
+  box-shadow: 4px 0 20px rgba(0, 0, 0, 0.35);
+  background-color: var(--stgr-bg-surface, #14141F);
+}
+
+/* --- PINNED STATE (stays expanded) ---------------------------------- */
+.stgr-vertical-tabs-panel[autohide="true"][pinned="true"] {
+  box-shadow: 4px 0 12px rgba(0, 0, 0, 0.25);
+}
+
+/* --- COLLAPSED GRADIENT INDICATOR ----------------------------------- */
+/* A subtle vertical gradient bar in the center of the collapsed strip */
+.stgr-vertical-tabs-panel[autohide="true"]:not([expanded="true"])::before {
+  content: "";
+  position: absolute;
+  left: 4px;
+  top: 25%;
+  bottom: 25%;
+  width: 3px;
+  border-radius: 2px;
+  background: linear-gradient(
+    180deg,
+    var(--stgr-accent-primary, #C41E3A) 0%,
+    var(--stgr-accent-secondary, #8B0000) 60%,
+    var(--stgr-accent-primary, #C41E3A) 100%
+  );
+  opacity: 0.35;
+  transition: opacity 0.2s ease;
+}
+
+.stgr-vertical-tabs-panel[autohide="true"]:not([expanded="true"]):hover::before {
+  opacity: 0.7;
+}
+
+/* --- HIDE CHILDREN WHEN COLLAPSED ----------------------------------- */
+.stgr-vertical-tabs-panel[autohide="true"]:not([expanded="true"]) > * {
+  opacity: 0;
+  pointer-events: none;
+  transition: opacity 0.1s ease;
+}
+
+.stgr-vertical-tabs-panel[autohide="true"][expanded="true"] > * {
+  opacity: 1;
+  pointer-events: auto;
+  transition: opacity 0.2s ease 0.1s;
+}
+
+/* --- PIN BUTTON ----------------------------------------------------- */
+.stgr-vertical-tabs-pin {
+  -moz-appearance: none;
+  appearance: none;
+  background: transparent;
+  border: none;
+  border-radius: 4px;
+  color: var(--stgr-text-secondary, #9090A0);
+  cursor: default;
+  font-size: 11px;
+  padding: 4px 8px;
+  transition: background-color 0.12s ease, color 0.12s ease;
+}
+
+.stgr-vertical-tabs-pin:hover {
+  background-color: var(--stgr-hover, #1A1A2E);
+  color: var(--stgr-text-primary, #E8E8F0);
+}
+
+.stgr-vertical-tabs-pin[checked="true"] {
+  color: var(--stgr-accent-primary, #C41E3A);
+}
+
+.stgr-vertical-tabs-pin[checked="true"]:hover {
+  color: var(--stgr-accent-secondary, #8B0000);
+}
