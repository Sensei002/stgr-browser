+  /**
+   * Navigate through search results by delta (+1 = down, -1 = up).
+   */
+  _navigateSearchResults(delta) {
+    const results = this._searchVisibleResults;
+    if (!results.length) return;
+
+    // Remove focus from current item
+    if (this._searchResultIndex >= 0 && this._searchResultIndex < results.length) {
+      results[this._searchResultIndex].removeAttribute("search-focused");
+    }
