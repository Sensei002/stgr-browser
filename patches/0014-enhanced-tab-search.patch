+  /**
+   * Check if a string matches a fuzzy query.
+   * E.g., fuzzyMatch("gthb", "GitHub") returns true.
+   * Characters in the query must appear in order in the target,
+   * but not necessarily contiguously.
+   */
+  _fuzzyMatch(query, target) {
+    const q = query.toLowerCase();
+    const t = target.toLowerCase();
+    let qi = 0;
+    for (let ti = 0; ti < t.length && qi < q.length; ti++) {
+      if (t[ti] === q[qi]) qi++;
+    }
+    return qi === q.length;
+  }
+
