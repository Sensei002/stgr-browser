+  // -----------------------------------------------------------------------
+  // THUMBNAIL CAPTURE
+  // -----------------------------------------------------------------------
+
+  /**
+   * Capture a thumbnail image of a tab's browser content.
+   * @param {Tab} tab
+   * @returns {Promise<string|null>}
+   */
+  async _captureThumbnail(tab) {
+    const browser = tab.linkedBrowser;
+    if (!browser || tab.hasAttribute("busy") || !browser.contentWindow) {
+      return null;
+    }
+
+    const url = browser.currentURI?.spec;
+    if (!url || url === "about:blank" || url === "about:newtab" ||
+        url === "about:home" || url === "about:preferences") {
+      return null;
+    }
+
+    // Check LRU cache (30 second TTL)
+    const cached = this._thumbnailCache.get(tab);
+    if (cached && (Date.now() - cached.timestamp) < 30000) {
+      return cached.dataUrl;
+    }
+
+    try {
+      let dataUrl = null;
+
+      if (lazy.PageThumbs) {
+        dataUrl = await this._captureViaPageThumbs(browser);
+      }
+      if (!dataUrl) {
+        dataUrl = await this._captureViaCanvas(browser);
+      }
+
+      if (dataUrl) {
+        // LRU eviction
+        if (this._thumbnailCache.size >= this._thumbnailCacheMax) {
+          const oldest = this._thumbnailCache.keys().next().value;
+          if (oldest) this._thumbnailCache.delete(oldest);
+        }
+        this._thumbnailCache.set(tab, { dataUrl, timestamp: Date.now() });
+      }
+
+      return dataUrl;
+    } catch (e) {
+      return null;
+    }
+  }
+
+  /**
+   * Capture via PageThumbs API.
+   * @param {XULBrowserElement} browser
+   * @returns {Promise<string|null>}
+   */
+  _captureViaPageThumbs(browser) {
+    return new Promise((resolve) => {
+      try {
+        lazy.PageThumbs.capture(
+          browser,
+          (canvas) => {
+            if (!canvas) { resolve(null); return; }
+            try {
+              const doc = this._win.document;
+              const scaled = doc.createElement("canvas");
+              scaled.width = this._thumbnailWidth;
+              scaled.height = this._thumbnailHeight;
+              const ctx = scaled.getContext("2d");
+              ctx.drawImage(canvas, 0, 0,
+                this._thumbnailWidth, this._thumbnailHeight);
+              resolve(scaled.toDataURL("image/jpeg", 70));
+            } catch (e) {
+              resolve(null);
+            }
+          },
+          this._thumbnailWidth,
+          this._thumbnailHeight
+        );
+      } catch (e) {
+        resolve(null);
+      }
+    });
+  }
+
+  /**
+   * Capture via canvas.drawWindow (fallback).
+   * @param {XULBrowserElement} browser
+   * @returns {Promise<string|null>}
+   */
+  _captureViaCanvas(browser) {
+    return new Promise((resolve) => {
+      try {
+        const contentWindow = browser.contentWindow;
+        if (!contentWindow) { resolve(null); return; }
+
+        const doc = this._win.document;
+        const canvas = doc.createElement("canvas");
+        canvas.width = this._thumbnailWidth;
+        canvas.height = this._thumbnailHeight;
+        const ctx = canvas.getContext("2d");
+
+        ctx.drawWindow(
+          contentWindow,
+          contentWindow.scrollX,
+          contentWindow.scrollY,
+          this._thumbnailWidth,
+          this._thumbnailHeight,
+          "rgb(255,255,255)",
+          ctx.DRAWWINDOW_DRAW_CARET |
+          ctx.DRAWWINDOW_DRAW_VIEW |
+          ctx.DRAWWINDOW_USE_WIDGET_LAYERS
+        );
+
+        resolve(canvas.toDataURL("image/jpeg", 70));
+      } catch (e) {
+        resolve(null);
+      }
+    });
+  }
+
+  /** Invalidate cache for a specific tab. */
+  _invalidateThumbnailCache(tab) {
+    this._thumbnailCache.delete(tab);
+  }
+
+  /** Prune expired entries from the thumbnail cache. */
+  _pruneCache() {
+    const now = Date.now();
+    for (const [tab, entry] of this._thumbnailCache) {
+      if (now - entry.timestamp > 30000) {
+        this._thumbnailCache.delete(tab);
+      }
+    }
+  }

