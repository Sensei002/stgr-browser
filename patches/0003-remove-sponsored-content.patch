From: STGR Browser Team <dev@stgr-browser.dev>
Date: Mon, 1 Jul 2026 00:00:00 +0000
Subject: Remove sponsored content, recommendations, and shopping

Removes:
- Sponsored top sites on new tab page
- Sponsored suggestions in URL bar
- Shopping experience (reviews, price tracking)
- Contextual feature recommendations
- Weather suggestions in URL bar
- Yelp suggestions
- Pocket recommendations
- Add-on recommendations/CFR
- New tab page activity stream sponsored features

diff --git a/browser/components/newtab/lib/ActivityStream.jsm b/browser/components/newtab/lib/ActivityStream.jsm
index 000000000000..000000000000 100644
--- a/browser/components/newtab/lib/ActivityStream.jsm
+++ b/browser/components/newtab/lib/ActivityStream.jsm
@@ -0,0 +1,38 @@
+// STGR Browser: ActivityStream without sponsored content
+// Modified to remove all sponsored and recommended content features
+
+const { XPCOMUtils } = ChromeUtils.importESModule(
+  "resource://gre/modules/XPCOMUtils.sys.mjs"
+);
+
+const lazy = {};
+
+XPCOMUtils.defineLazyPreferenceGetter(
+  lazy,
+  "showSponsored",
+  "browser.newtabpage.activity-stream.showSponsored",
+  false
+);
+
+// STGR: Override to always disable sponsored content
+function isSponsoredContentEnabled() {
+  return false;
+}
+
+// Remove sponsored top sites from the feed
+function filterSponsoredSites(sites) {
+  if (!sites) return sites;
+  return sites.filter(site => !site.sponsored);
+}

diff --git a/browser/components/newtab/lib/TopSitesFeed.jsm b/browser/components/newtab/lib/TopSitesFeed.jsm
index 000000000000..000000000000 100644
--- a/browser/components/newtab/lib/TopSitesFeed.jsm
+++ b/browser/components/newtab/lib/TopSitesFeed.jsm
@@ -0,0 +1,10 @@
+// STGR Browser: Remove sponsored top sites
+// This patch removes sponsored top sites insertion and filtering
+
+// Override: Do not insert sponsored top sites
+TopSitesFeed.prototype._fetchSites = async function() {
+  const sites = await this._fetchDefaults();
+  // STGR: No sponsored sites inserted
+  return sites.filter(site => !site.sponsored);
+};

