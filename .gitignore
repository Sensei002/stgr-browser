# STGR Browser - .gitignore

# Firefox source tree (30+ GB, cloned by setup.sh)
gecko-dev/

# Build artifacts
obj-build-*/
obj-*/

# Firefox build artifacts
*.o
*.obj
*.lib
*.dll
*.exe
*.so
*.dylib
*.a
*.la
*.lo
*.class
*.jar
*.war

# Rust build artifacts
target/
Cargo.lock

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Generated icons
branding/icons/png/
branding/icons/stgr.iconset/
branding/icons/*.ico
branding/icons/*.bmp
branding/icons/STGR_ICNS_GENERATION.txt
branding/stgr.ico
branding/stgr.icns
branding/installer.ico
branding/logo-1024.png
branding/linux/

# Generated splash screen (regenerated from logo.png)
assets/splash-screen.svg

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
*.log
logs/

# Local patch rejects (generated by git apply --reject)
*.rej

# Editor temp files from patching
*.orig
