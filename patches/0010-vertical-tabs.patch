diff --git a/browser/base/content/browser.js b/browser/base/content/browser.js
index 000000000000..000000000000 100644
--- a/browser/base/content/browser.js
+++ b/browser/base/content/browser.js
@@ -0,0 +1,40 @@
+// STGR Browser: Vertical tabs integration
+ChromeUtils.import("resource:///modules/VerticalTabs.jsm");
+
+// Add toolbar toggle button (guard against duplicate registration)
+if (!CustomizableUI.getWidget("stgr-vertical-tabs-toggle")) {
+  CustomizableUI.createWidget({
+    id: "stgr-vertical-tabs-toggle",
+    type: "toggle",
+    label: "Vertical Tabs",
+    tooltiptext: "Toggle vertical tab layout (Ctrl+Shift+E)",
+    defaultArea: CustomizableUI.AREA_NAVBAR,
+
+    onCreated(aButton) {
+      aButton.classList.add("stgr-vertical-tabs-toggle-button");
+      const enabled = Services.prefs.getBoolPref(
+        "stgr.verticalTabs.enabled", false);
+      aButton.setAttribute("checked", enabled);
+      return aButton;
+    },
+
+    onCommand() {
+      const { VerticalTabs } = ChromeUtils.import(
+        "resource:///modules/VerticalTabs.jsm");
+      VerticalTabs.toggle();
+    },
+  });
+}
+
+// Keyboard shortcut (Ctrl+Shift+E) is registered dynamically by VerticalTabs.jsm
+// via _registerShortcut() which appends a <key> element to the #mainKeyset.
+// This is only kept as a static fallback for when the dynamic registration fails.
