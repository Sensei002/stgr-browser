From: STGR Browser Team <dev@stgr-browser.dev>
Date: Tue, 7 Jul 2026 00:00:00 +0000
Subject: STGR Browser preferences pane controller and localization

Adds the STGR preferences pane controller (stgr.js), localization (stgr.ftl),
and build registration (moz.build). Also updates the vertical tabs settings
button to navigate to the correct pane.

Integration into preferences.xhtml and preferences.js is a manual step
that must be done after cloning the Firefox source (see docs/STGR_PREFERENCES.md).

diff --git a/browser/components/preferences/in-content/stgr.js b/browser/components/preferences/in-content/stgr.js
new file mode 100644
index 000000000000..000000000000
--- /dev/null
+++ b/browser/components/preferences/in-content/stgr.js
@@ -0,0 +1,155 @@
+/* -*- Mode: JS; tab-width: 2; indent-tabs-mode: nil; c-basic-offset: 2 -*- */
+/* This Source Code Form is subject to the terms of the Mozilla Public
+ * License, v. 2.0. If a copy of the MPL was not distributed with this
+ * file, You can obtain one at http://mozilla.org/MPL/2.0/. */
+
+// STGR Browser: Preferences pane controller
+
+var STGRPreferences = {
+  _observers: [],
+
+  init() {
+    this._bindVerticalTabs();
+    this._bindTabGroups();
+    this._bindTabPreview();
+    this._bindGamingMode();
+    this._initAbout();
+    this._setupShutdown();
+  },
+
+  // Vertical Tabs
+
+  _bindVerticalTabs() {
+    this._bindCheckbox("stgrVerticalTabsEnabled", "stgr.verticalTabs.enabled");
+    this._bindSlider("stgrVerticalTabsWidth", "stgr.verticalTabs.width",
+                     "stgrVerticalTabsWidthValue", "px");
+    this._bindCheckbox("stgrVerticalTabsAutoHide", "stgr.verticalTabs.autoHide");
+    this._bindCheckbox("stgrVerticalTabsShowPreview", "stgr.verticalTabs.showPreview");
+    this._bindCheckbox("stgrVerticalTabsSearchEnabled", "stgr.verticalTabs.searchEnabled");
+    this._bindCheckbox("stgrVerticalTabsSearchFuzzy", "stgr.verticalTabs.searchFuzzy");
+    this._bindCheckbox("stgrVerticalTabsSearchUrls", "stgr.verticalTabs.searchUrls");
+    this._bindCheckbox("stgrVerticalTabsAnimations", "stgr.verticalTabs.animations");
+  },
+
+  // Tab Groups
+
+  _bindTabGroups() {
+    this._bindCheckbox("stgrTabGroupsEnabled", "stgr.tabGroups.enabled");
+    this._bindCheckbox("stgrTabGroupsShowColorDot", "stgr.tabGroups.showColorDot");
+    this._bindCheckbox("stgrTabGroupsCollapseOnStartup", "stgr.tabGroups.collapseOnStartup");
+  },
+
+  // Tab Preview
+
+  _bindTabPreview() {
+    this._bindSlider("stgrPreviewWidth", "stgr.verticalTabs.previewWidth",
+                     "stgrPreviewWidthValue", "px");
+    this._bindSlider("stgrPreviewHeight", "stgr.verticalTabs.previewHeight",
+                     "stgrPreviewHeightValue", "px");
+    this._bindSlider("stgrPreviewQuality", "stgr.verticalTabs.previewQuality",
+                     "stgrPreviewQualityValue", "");
+  },
+
+  // Gaming Mode
+
+  _bindGamingMode() {
+    this._bindCheckbox("stgrGamingModeEnabled", "stgr.gamingMode.enabled");
+  },
+
+  // About
+
+  _initAbout() {
+    const appInfo = Services.appinfo;
+    const verEl = document.getElementById("stgrAboutVersion");
+    if (verEl) verEl.textContent = appInfo.version || "1.0.0";
+    const buildEl = document.getElementById("stgrAboutBuild");
+    if (buildEl) buildEl.textContent = appInfo.appBuildID || "20260701";
+    const platEl = document.getElementById("stgrAboutPlatform");
+    if (platEl) platEl.textContent = appInfo.OS || "Unknown";
+  },
+
+  // Binding Helpers
+
+  _bindCheckbox(elementId, prefName) {
+    const el = document.getElementById(elementId);
+    if (!el) return;
+    const pref = Services.prefs.getBoolPref(prefName, false);
+    el.checked = pref;
+    el.addEventListener("command", () => {
+      Services.prefs.setBoolPref(prefName, el.checked);
+    });
+    const obs = (subject, topic, data) => {
+      if (data === prefName) {
+        el.checked = Services.prefs.getBoolPref(prefName, false);
+      }
+    };
+    Services.prefs.addObserver(prefName, obs);
+    this._observers.push({ pref: prefName, observer: obs });
+  },
+
+  _bindSlider(elementId, prefName, valueLabelId, suffix) {
+    const el = document.getElementById(elementId);
+    const label = document.getElementById(valueLabelId);
+    if (!el) return;
+    const initial = Services.prefs.getIntPref(prefName, 260);
+    el.value = initial;
+    if (label) label.textContent = `${initial}${suffix}`;
+    el.addEventListener("input", () => {
+      const val = parseInt(el.value, 10);
+      Services.prefs.setIntPref(prefName, val);
+      if (label) label.textContent = `${val}${suffix}`;
+    });
+    const obs = (subject, topic, data) => {
+      if (data === prefName) {
+        const val = Services.prefs.getIntPref(prefName, 260);
+        el.value = val;
+        if (label) label.textContent = `${val}${suffix}`;
+      }
+    };
+    Services.prefs.addObserver(prefName, obs);
+    this._observers.push({ pref: prefName, observer: obs });
+  },
+
+  // Lifecycle
+
+  _setupShutdown() {
+    window.addEventListener("unload", () => this.shutdown());
+  },
+
+  shutdown() {
+    for (const { pref, observer } of this._observers) {
+      Services.prefs.removeObserver(pref, observer);
+    }
+    this._observers = [];
+  },
+};
