# STGR Browser - macOS Optimized mozconfig
# ============================================================================
# For macOS builds (both Intel x86_64 and Apple Silicon ARM64)
# Uses Cocoa toolkit, Metal graphics API, VideoToolbox hardware decode,
# and supports universal binary (x86_64 + arm64) builds.
# ============================================================================

# Build project
ac_add_options --enable-application=browser

# Branding
ac_add_options --with-app-name=stgr-browser
ac_add_options --with-app-basename=STGR
ac_add_options --with-branding=stgr/branding
ac_add_options --with-unsigned-addon-scopes=app,system
ac_add_options --allow-addon-sideload

# Architecture optimizations
# Auto-detect architecture (Intel vs Apple Silicon)
_STGR_MACHINE=$(uname -m)
case "$_STGR_MACHINE" in
    arm64)
        ac_add_options --enable-optimize="-O3 -mcpu=apple-m1"
        ;;
    x86_64)
        ac_add_options --enable-optimize="-O3"
        ;;
    *)
        ac_add_options --enable-optimize="-O3"
        ;;
esac

ac_add_options --enable-debug-symbols
ac_add_options --enable-release

# macOS deployment target (supports macOS 11 Big Sur+)
ac_add_options --enable-macos-target=11.0

# Security
ac_add_options --enable-hardening
ac_add_options --enable-fuzzing-safe
ac_add_options --enable-pie
ac_add_options --enable-sandbox
ac_add_options --enable-site-isolation

# Graphics - macOS specific (Metal via WebRender)
ac_add_options --enable-default-toolkit=cairo-cocoa
ac_add_options --enable-webrender
ac_add_options --enable-gpu-rasterization
ac_add_options --enable-skia
ac_add_options --enable-webgl

# Performance
ac_add_options --enable-jemalloc
ac_add_options --enable-pgo
ac_add_options --enable-lto
ac_add_options --enable-ffmpeg
ac_add_options --enable-av1

# Disable unnecessary features
ac_add_options --disable-crashreporter
ac_add_options --disable-tests
ac_add_options --disable-debug
ac_add_options --disable-profiling
ac_add_options --disable-js-shell
ac_add_options --disable-geckoview
ac_add_options --disable-necko-wifi
ac_add_options --disable-parental-controls

# Media - macOS specific
ac_add_options --enable-openh264
ac_add_options --enable-hardware-media-keys

# Codec support
ac_add_options --with-system-png
ac_add_options --with-system-jpeg
ac_add_options --with-system-zlib

# Build output
mk_add_options MOZ_OBJDIR=@TOPSRCDIR@/obj-build-stgr

# macOS bundle
ac_add_options --enable-macbundle
